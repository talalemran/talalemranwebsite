---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import Ava from "../assets/01.jpg";
import Canada from "../assets/discovercanada-small.webp";
import MyOldWebsite from "../assets/myoldwebsite-small.webp";
import SuperTire from "../assets/supertire-small.webp";
const pageTitle = "Talal Emran - Web Designer & Developer";
const pageDescription =
    "Welcome to my personal website. I am a web designer, developer, graphic designer, and photographer with over 10 years of experience.";
